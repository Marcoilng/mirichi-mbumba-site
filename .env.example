# ============================================================
# FICHIER D'EXEMPLE — Copiez ce fichier en .env et remplissez
# les valeurs. Le fichier .env NE DOIT JAMAIS être commité.
# ============================================================
#
# INSTRUCTIONS :
# 1. Copiez ce fichier : cp .env.example .env
# 2. Remplissez vos vraies valeurs Supabase ci-dessous
# 3. Ajoutez ces variables dans Vercel > Project Settings > Environment Variables
#
# Ces variables sont injectées en meta tags dans les HTML
# lors du build par scripts/prepare-deploy.mjs
# ============================================================

# URL du projet Supabase (trouvée dans : Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Clé publique anonyme Supabase (anon key — safe for frontend)
# Trouvée dans : Project Settings > API > anon public
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Note : La clé SERVICE_ROLE (admin) NE DOIT JAMAIS être
# utilisée côté frontend. Elle reste uniquement sur le serveur.
